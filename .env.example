DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

# Base URL of the frontend; used to build the Open Banking redirect (/bank-callback)
FRONTEND_URL=http://localhost:5173

# Open Banking (Enable Banking) app credentials.
# Register an application in the Enable Banking Control Panel (upload an RSA
# self-signed cert) to obtain the application id; sign API requests with the
# matching RSA private key.
ENABLE_BANKING_APP_ID=
# Provide the RSA private key either as a file path...
ENABLE_BANKING_PRIVATE_KEY_PATH=
# ...or inline (PEM with \n escaped newlines). Only one is needed.
ENABLE_BANKING_PRIVATE_KEY=
# Optional override; defaults to https://api.enablebanking.com
ENABLE_BANKING_BASE_URL=

# Fernet key used to encrypt stored bank connector tokens (optional)
BANK_CONNECTOR_ENCRYPTION_KEY=
