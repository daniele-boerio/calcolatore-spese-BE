DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
SECRET_KEY=
ALGORITHM=

# "production" chiude /docs, /redoc e /openapi.json (in dev restano aperti).
ENVIRONMENT=development

# --- Sessione ---------------------------------------------------------------
# L'access token (Bearer, in localStorage) è volutamente breve: se viene rubato la
# finestra di abuso è di minuti. La sessione lunga la regge il refresh token, che
# sta in un cookie httpOnly e non è leggibile da JavaScript.
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Per quanti giorni si resta loggati su un dispositivo senza reinserire la password.
REFRESH_TOKEN_EXPIRE_DAYS=90

# Cookie del refresh token. In produzione (https) lasciare "true": con "false" il
# cookie viaggerebbe in chiaro. Metterlo a "false" SOLO in locale su http.
COOKIE_SECURE=true
# Dominio del cookie. Va lasciato VUOTO: così il cookie resta legato al solo host
# del BE (conti-be.spassocasa.it) e non viene esposto agli altri sottodomini.
# Funziona lo stesso perché FE e BE condividono il dominio registrabile
# (spassocasa.it) e quindi le chiamate dal FE al BE sono same-site: con
# SameSite=Lax il cookie viene inviato regolarmente.
# Valorizzarlo (es. ".spassocasa.it") solo se il BE dovesse cambiare host.
COOKIE_DOMAIN=

# Base URL of the frontend; used to build the Open Banking redirect (/bank-callback)
FRONTEND_URL=http://localhost:5173

# --- Open Banking (solo utente admin) ---------------------------------------
# Open Banking (Enable Banking) app credentials.
# Register an application in the Enable Banking Control Panel (upload an RSA
# self-signed cert) to obtain the application id; sign API requests with the
# matching RSA private key.
ENABLE_BANKING_APP_ID=
# Provide the RSA private key either as a file path...
ENABLE_BANKING_PRIVATE_KEY_PATH=
# ...or inline (PEM with \n escaped newlines). Only one is needed.
ENABLE_BANKING_PRIVATE_KEY=
# Optional override; defaults to https://api.enablebanking.com
ENABLE_BANKING_BASE_URL=

# Open Banking is restricted to this single user (your email). Other authenticated
# users get a 403. Required for the Open Banking endpoints to work at all.
# Vale anche per il salvataggio delle credenziali del connettore e per la sync.
OPEN_BANKING_ADMIN_EMAIL=

# Chiave Fernet per cifrare i token bancari salvati. OBBLIGATORIA se usi l'Open
# Banking: senza, gli endpoint bancari falliscono invece di salvare i token in
# chiaro. Gli utenti che non collegano una banca non ne hanno bisogno e l'app
# funziona normalmente senza.
# Generala con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_CONNECTOR_ENCRYPTION_KEY=

# --- SMTP (email di reset password) -----------------------------------------
# Se non configurato, il link di reset viene solo loggato (utile in sviluppo).
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
